    <model name="east_evaluation_zone">
      <static>true</static>
      <link name="evaluation_features">
        <!-- 東側だけ床を分割し、段差・溝・穴・スロープを同居させて観測対象をまとめる。 -->
        <collision name="eval_floor_left_collision"><pose>39 -2 -0.05 0 0 0</pose><geometry><box><size>18 20 0.1</size></box></geometry></collision>
