        <visual name="eval_floor_upper_visual"><pose>48 6.75 -0.05 0 0 0</pose><geometry><box><size>18 6.5 0.1</size></box></geometry><material><ambient>0.24 0.24 0.24 1</ambient><diffuse>0.40 0.40 0.40 1</diffuse></material></visual>
