    <model name="dock_wall_north">
      <static>true</static>
      <pose>3.0 5.0 1.0 0 0 0</pose>
      <link name="link">
        <!-- 既存worldと同じ高さ・厚みの外壁で、拡張した床外周を閉じる。 -->
        <collision name="collision"><geometry><box><size>24.0 0.25 2.0</size></box></geometry></collision>
        <visual name="visual"><geometry><box><size>24.0 0.25 2.0</size></box></geometry><material><ambient>0.45 0.42 0.38 1</ambient><diffuse>0.45 0.42 0.38 1</diffuse></material></visual>
      </link>
    </model>

    <model name="dock_wall_south">
      <static>true</static>
      <pose>3.0 -5.0 1.0 0 0 0</pose>
      <link name="link">
        <collision name="collision"><geometry><box><size>24.0 0.25 2.0</size></box></geometry></collision>
        <visual name="visual"><geometry><box><size>24.0 0.25 2.0</size></box></geometry><material><ambient>0.45 0.42 0.38 1</ambient><diffuse>0.45 0.42 0.38 1</diffuse></material></visual>
      </link>
    </model>

    <model name="dock_wall_east">
      <static>true</static>
      <pose>15.0 0 1.0 0 0 0</pose>
      <link name="link">
        <collision name="collision"><geometry><box><size>0.25 10.0 2.0</size></box></geometry></collision>
        <visual name="visual"><geometry><box><size>0.25 10.0 2.0</size></box></geometry><material><ambient>0.45 0.42 0.38 1</ambient><diffuse>0.45 0.42 0.38 1</diffuse></material></visual>
      </link>
    </model>

    <model name="dock_wall_west">
      <static>true</static>
      <pose>-9.0 0 1.0 0 0 0</pose>
      <link name="link">
        <collision name="collision"><geometry><box><size>0.25 10.0 2.0</size></box></geometry></collision>
        <visual name="visual"><geometry><box><size>0.25 10.0 2.0</size></box></geometry><material><ambient>0.45 0.42 0.38 1</ambient><diffuse>0.45 0.42 0.38 1</diffuse></material></visual>
      </link>
    </model>

    <model name="ceiling">
      <static>true</static>
      <pose>3.0 0 2.05 0 0 0</pose>
      <link name="link">
        <!-- 天井は既存worldと同様にLiDAR ray用の衝突を持たせ、表示だけ透明にする。 -->
        <collision name="collision"><geometry><box><size>24.0 10.25 0.10</size></box></geometry></collision>
        <visual name="visual">
          <geometry><box><size>24.0 10.25 0.10</size></box></geometry>
          <material><ambient>0.35 0.35 0.38 0</ambient><diffuse>0.35 0.35 0.38 0</diffuse></material>
          <transparency>1.0</transparency>
        </visual>
      </link>
    </model>
  </world>
</sdf>
