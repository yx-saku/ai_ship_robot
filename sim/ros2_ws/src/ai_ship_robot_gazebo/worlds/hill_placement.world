<?xml version="1.0" ?>
<sdf version="1.6">
  <world name="hill_placement">
    <gravity>0 0 -9.80511</gravity>
    <magnetic_field>6.0e-6 2.3e-5 -4.2e-5</magnetic_field>
    <atmosphere type="adiabatic" />
    <!-- /clock の更新粒度を上げるため、physics step を 1ms 基準に固定する。 -->
    <physics type="ode">
      <real_time_update_rate>1000</real_time_update_rate>
      <max_step_size>0.001</max_step_size>
      <real_time_factor>1.0</real_time_factor>
    </physics>

    <light name="sun" type="directional">
      <cast_shadows>true</cast_shadows>
      <pose>0 0 10 0 0 0</pose>
      <diffuse>0.8 0.8 0.8 1</diffuse>
      <specular>0.2 0.2 0.2 1</specular>
      <attenuation>
        <range>1000</range>
        <constant>0.9</constant>
        <linear>0.01</linear>
        <quadratic>0.001</quadratic>
      </attenuation>
      <direction>-0.5 0.1 -0.9</direction>
    </light>

    <model name="flat_floor">
      <static>true</static>
      <!-- 8個の丘を前方へ並べられるよう、既存worldよりX方向を広くした平坦床を用意する。 -->
      <link name="link">
        <collision name="collision">
          <pose>3.0 0 -0.01 0 0 0</pose>
          <geometry>
            <box><size>24.0 10.0 0.02</size></box>
          </geometry>
        </collision>
        <visual name="visual">
          <pose>3.0 0 -0.01 0 0 0</pose>
          <geometry>
            <box><size>24.0 10.0 0.02</size></box>
          </geometry>
          <material>
            <ambient>0.30 0.30 0.30 1</ambient>
            <diffuse>0.55 0.55 0.55 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <model name="hill_constant_5deg">
      <static>true</static>
      <pose>-1.9742 -1.5 0 0 0 0</pose>
      <!-- 5度の一定勾配丘は厚みを持つ傾斜直方体で側面を兼ね、上面高さ10cmを維持する。 -->
