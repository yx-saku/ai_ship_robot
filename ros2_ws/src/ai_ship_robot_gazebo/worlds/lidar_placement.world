<?xml version="1.0" ?>
<sdf version="1.6">
  <world name="lidar_placement">
    <gravity>0 0 -9.81</gravity>
    <magnetic_field>6.0e-6 2.3e-5 -4.2e-5</magnetic_field>
    <atmosphere type="adiabatic" />

    <light name="sun" type="directional">
      <cast_shadows>true</cast_shadows>
      <pose>0 0 10 0 0 0</pose>
      <diffuse>0.8 0.8 0.8 1</diffuse>
      <specular>0.2 0.2 0.2 1</specular>
      <attenuation>
        <range>1000</range>
        <constant>0.9</constant>
        <linear>0.01</linear>
        <quadratic>0.001</quadratic>
      </attenuation>
      <direction>-0.5 0.1 -0.9</direction>
    </light>

    <model name="ground_with_defects">
      <static>true</static>
      <!-- 穴部分だけ床タイルを抜き、LiDAR rayが地面に当たらない領域を作る。 -->
      <link name="ground_tiles">
        <collision name="south_area_collision">
          <pose>0 -3.125 -0.01 0 0 0</pose>
          <geometry>
            <box><size>12.0 3.75 0.02</size></box>
          </geometry>
        </collision>
        <visual name="south_area_visual">
          <pose>0 -3.125 -0.01 0 0 0</pose>
          <geometry>
            <box><size>12.0 3.75 0.02</size></box>
          </geometry>
          <material>
            <ambient>0.30 0.30 0.30 1</ambient>
            <diffuse>0.55 0.55 0.55 1</diffuse>
          </material>
        </visual>
        <collision name="center_area_collision">
          <pose>0 0 -0.01 0 0 0</pose>
          <geometry>
            <box><size>12.0 2.30 0.02</size></box>
          </geometry>
        </collision>
        <visual name="center_area_visual">
          <pose>0 0 -0.01 0 0 0</pose>
          <geometry>
            <box><size>12.0 2.30 0.02</size></box>
          </geometry>
          <material>
            <ambient>0.30 0.30 0.30 1</ambient>
            <diffuse>0.55 0.55 0.55 1</diffuse>
          </material>
        </visual>
        <collision name="north_area_collision">
          <pose>0 3.375 -0.01 0 0 0</pose>
          <geometry>
            <box><size>12.0 3.25 0.02</size></box>
          </geometry>
        </collision>
        <visual name="north_area_visual">
          <pose>0 3.375 -0.01 0 0 0</pose>
          <geometry>
            <box><size>12.0 3.25 0.02</size></box>
          </geometry>
          <material>
            <ambient>0.30 0.30 0.30 1</ambient>
            <diffuse>0.55 0.55 0.55 1</diffuse>
          </material>
        </visual>

        <!-- 右側の溝帯だけ床面を抜き、溝の幅に応じて残る床面を補う。 -->
        <collision name="south_hole_row_left_collision">
