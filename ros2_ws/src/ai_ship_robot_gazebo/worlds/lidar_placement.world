        <visual name="rim_visual"><geometry><mesh><uri>../meshes/annulus_unit.obj</uri><scale>0.015 0.015 1</scale></mesh></geometry><material><ambient>0.30 0.30 0.30 1</ambient><diffuse>0.55 0.55 0.55 1</diffuse></material></visual>
        <collision name="wall_collision"><pose>0 0 -0.001 0 0 0</pose><geometry><mesh><uri>../meshes/cylinder_wall_unit.obj</uri><scale>0.015 0.015 1.0</scale></mesh></geometry></collision>
        <visual name="wall_visual"><pose>0 0 -0.001 0 0 0</pose><geometry><mesh><uri>../meshes/cylinder_wall_unit.obj</uri><scale>0.015 0.015 1.0</scale></mesh></geometry><material><ambient>0.12 0.12 0.12 1</ambient><diffuse>0.18 0.18 0.18 1</diffuse></material></visual>
      </link>

