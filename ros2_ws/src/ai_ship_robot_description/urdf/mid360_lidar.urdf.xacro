<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="mid360_lidar">
  <xacro:arg name="half_lidar_resolution" default="false" />
  <xacro:arg name="quarter_lidar_resolution" default="false" />

  <xacro:property name="mid360_depth" value="0.060" />
  <xacro:property name="mid360_width" value="0.065" />
  <xacro:property name="mid360_height" value="0.065" />
  <xacro:property name="mid360_samples" value="40000" />
  <xacro:property name="mid360_downsample" value="1" />
  <xacro:property name="mid360_half_downsample" value="2" />
  <xacro:property name="mid360_quarter_downsample" value="4" />

  <xacro:macro name="mid360_gazebo_sensor" params="prefix">
    <gazebo reference="${prefix}_lidar_link">
      <sensor name="${prefix}_lidar_link" type="ray">
        <always_on>true</always_on>
        <visualize>false</visualize>
        <update_rate>10</update_rate>
        <!-- Livox pluginの要求に合わせ、可視化用のray設定とCSV走査設定を同居させる。 -->
        <plugin name="${prefix}_livox_plugin" filename="libros2_livox.so">
          <ray>
            <scan>
              <horizontal>
                <samples>100</samples>
                <resolution>1</resolution>
                <min_angle>0</min_angle>
                <max_angle>${2.0 * pi}</max_angle>
              </horizontal>
              <vertical>
                <samples>360</samples>
                <resolution>1</resolution>
                <min_angle>${-7.22 * pi / 180.0}</min_angle>
                <max_angle>${55.22 * pi / 180.0}</max_angle>
              </vertical>
            </scan>
            <range>
              <min>0.10</min>
              <max>200.0</max>
              <resolution>0.002</resolution>
            </range>
            <noise>
              <type>gaussian</type>
              <mean>0.0</mean>
              <stddev>0.01</stddev>
            </noise>
          </ray>
          <visualize>false</visualize>
          <samples>${mid360_samples}</samples>
          <!-- downsample値だけでLivox pluginの負荷を切り替え、topic構成は維持する。 -->
          <xacro:if value="$(arg quarter_lidar_resolution)">
            <downsample>${mid360_quarter_downsample}</downsample>
          </xacro:if>
          <xacro:unless value="$(arg half_lidar_resolution)">
            <xacro:unless value="$(arg quarter_lidar_resolution)">
              <downsample>${mid360_downsample}</downsample>
            </xacro:unless>
          </xacro:unless>
          <xacro:if value="$(arg half_lidar_resolution)">
            <downsample>${mid360_half_downsample}</downsample>
          </xacro:if>
          <csv_file_name>$(find ros2_livox_simulation)/scan_mode/mid360.csv</csv_file_name>
          <topic>${prefix}_livox</topic>
          <custom_topic>/${prefix}_lidar/custom</custom_topic>
          <pointcloud2_topic>/${prefix}_lidar/points</pointcloud2_topic>
        </plugin>
      </sensor>
    </gazebo>
  </xacro:macro>

  <xacro:macro name="mid360_lidar" params="prefix x y z roll pitch yaw">
    <link name="${prefix}_lidar_link">
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <box size="${mid360_depth} ${mid360_width} ${mid360_height}" />
        </geometry>
        <material name="sensor_black">
          <color rgba="0.0 0.0 0.0 1.0" />
        </material>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <box size="${mid360_depth} ${mid360_width} ${mid360_height}" />
        </geometry>
      </collision>
      <xacro:box_inertia mass="0.265" x="${mid360_depth}" y="${mid360_width}" z="${mid360_height}" />
    </link>

    <joint name="${prefix}_lidar_joint" type="fixed">
      <parent link="base_link" />
      <child link="${prefix}_lidar_link" />
      <origin xyz="${x} ${y} ${z}" rpy="${roll} ${pitch} ${yaw}" />
    </joint>

    <xacro:if value="$(arg use_sim)">
      <xacro:mid360_gazebo_sensor prefix="${prefix}" />
    </xacro:if>
  </xacro:macro>
</robot>
