<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="ai_ship_robot">
  <xacro:arg name="use_sim" default="true" />

  <xacro:property name="base_length" value="0.72" />
  <xacro:property name="base_width" value="0.72" />
  <xacro:property name="base_height" value="0.37" />
  <xacro:property name="ground_clearance" value="0.03" />
  <xacro:property name="wheel_radius" value="0.10" />
  <xacro:property name="wheel_width" value="0.08" />
  <xacro:property name="wheel_separation" value="${base_width - wheel_width}" />
  <xacro:property name="wheel_x_offset" value="${base_length / 2.0 - wheel_radius - 0.02}" />
  <xacro:property name="base_center_z" value="${ground_clearance - wheel_radius + base_height / 2.0}" />

  <xacro:macro name="box_inertia" params="mass x y z">
    <inertial>
      <mass value="${mass}" />
      <origin xyz="0 0 0" rpy="0 0 0" />
      <inertia
        ixx="${mass * (y * y + z * z) / 12.0}"
        ixy="0"
        ixz="0"
        iyy="${mass * (x * x + z * z) / 12.0}"
        iyz="0"
        izz="${mass * (x * x + y * y) / 12.0}" />
    </inertial>
  </xacro:macro>

  <xacro:macro name="cylinder_inertia" params="mass radius length axis">
    <inertial>
      <mass value="${mass}" />
      <origin xyz="0 0 0" rpy="0 0 0" />
      <xacro:if value="${axis == 'y'}">
        <inertia
          ixx="${mass * (3.0 * radius * radius + length * length) / 12.0}"
          ixy="0"
          ixz="0"
          iyy="${mass * radius * radius / 2.0}"
          iyz="0"
          izz="${mass * (3.0 * radius * radius + length * length) / 12.0}" />
      </xacro:if>
      <xacro:unless value="${axis == 'y'}">
        <inertia
          ixx="${mass * (3.0 * radius * radius + length * length) / 12.0}"
          ixy="0"
          ixz="0"
          iyy="${mass * (3.0 * radius * radius + length * length) / 12.0}"
          iyz="0"
          izz="${mass * radius * radius / 2.0}" />
      </xacro:unless>
    </inertial>
  </xacro:macro>

  <xacro:macro name="drive_wheel" params="prefix x_position y_position">
    <link name="${prefix}_wheel_link">
      <visual>
        <origin xyz="0 0 0" rpy="${pi / 2.0} 0 0" />
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}" />
        </geometry>
        <material name="dark_gray">
          <color rgba="0.02 0.02 0.02 1.0" />
        </material>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="${pi / 2.0} 0 0" />
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}" />
        </geometry>
      </collision>
      <xacro:cylinder_inertia mass="1.2" radius="${wheel_radius}" length="${wheel_width}" axis="y" />
    </link>

    <joint name="${prefix}_wheel_joint" type="continuous">
      <parent link="base_link" />
      <child link="${prefix}_wheel_link" />
      <origin xyz="${x_position} ${y_position} 0" rpy="0 0 0" />
      <axis xyz="0 1 0" />
    </joint>

    <gazebo reference="${prefix}_wheel_link">
      <material>Gazebo/Black</material>
      <mu1>1.0</mu1>
      <mu2>1.0</mu2>
    </gazebo>
  </xacro:macro>

  <link name="base_footprint" />

  <joint name="base_footprint_joint" type="fixed">
    <parent link="base_footprint" />
    <child link="base_link" />
    <origin xyz="0 0 ${wheel_radius}" rpy="0 0 0" />
  </joint>

  <link name="base_link">
    <visual>
      <origin xyz="0 0 ${base_center_z}" rpy="0 0 0" />
      <geometry>
        <box size="${base_length} ${base_width} ${base_height}" />
      </geometry>
      <material name="navy_blue">
        <color rgba="0.02 0.08 0.18 1.0" />
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 ${base_center_z}" rpy="0 0 0" />
      <geometry>
        <box size="${base_length} ${base_width} ${base_height}" />
      </geometry>
    </collision>
    <xacro:box_inertia mass="28.0" x="${base_length}" y="${base_width}" z="${base_height}" />
  </link>

  <xacro:drive_wheel prefix="left_front" x_position="${wheel_x_offset}" y_position="${wheel_separation / 2.0}" />
  <xacro:drive_wheel prefix="left_rear" x_position="${-wheel_x_offset}" y_position="${wheel_separation / 2.0}" />
  <xacro:drive_wheel prefix="right_front" x_position="${wheel_x_offset}" y_position="${-wheel_separation / 2.0}" />
  <xacro:drive_wheel prefix="right_rear" x_position="${-wheel_x_offset}" y_position="${-wheel_separation / 2.0}" />

  <!-- ==================== LiDAR installation pattern ====================
       Edit the filename below to switch LiDAR installation patterns.

       lidar_pattern_dual.urdf.urdf.xacro
       lidar_pattern_single.urdf.urdf.xacro
       ================================================================ -->
  <!-- <xacro:include filename="lidar_pattern_dual.urdf.xacro" /> -->
  <xacro:include filename="lidar_pattern_single.urdf.xacro" />

  <link name="imu_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <box size="0.08 0.06 0.025" />
      </geometry>
      <material name="imu_green">
        <color rgba="0.0 0.35 0.18 1.0" />
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <box size="0.08 0.06 0.025" />
      </geometry>
    </collision>
    <xacro:box_inertia mass="0.1" x="0.08" y="0.06" z="0.025" />
  </link>

  <joint name="imu_joint" type="fixed">
    <parent link="base_link" />
    <child link="imu_link" />
    <origin xyz="0 0 ${base_center_z + base_height / 2.0 - 0.02}" rpy="0 0 0" />
  </joint>

  <gazebo reference="base_link">
    <material>Gazebo/Blue</material>
  </gazebo>
  <xacro:if value="$(arg use_sim)">
    <gazebo>
      <plugin name="planar_move_controller" filename="libgazebo_ros_planar_move.so">
        <ros>
          <remapping>cmd_vel:=cmd_vel</remapping>
          <remapping>odom:=odom</remapping>
        </ros>
        <update_rate>100.0</update_rate>
        <publish_rate>30.0</publish_rate>
        <publish_odom>true</publish_odom>
        <publish_odom_tf>true</publish_odom_tf>
        <odometry_frame>odom</odometry_frame>
        <robot_base_frame>base_footprint</robot_base_frame>
      </plugin>
    </gazebo>

    <gazebo reference="imu_link">
      <sensor name="imu" type="imu">
        <always_on>true</always_on>
        <update_rate>100</update_rate>
        <plugin name="imu_controller" filename="libgazebo_ros_imu_sensor.so">
          <ros>
            <remapping>~/out:=/imu/data</remapping>
          </ros>
          <frame_name>imu_link</frame_name>
        </plugin>
      </sensor>
    </gazebo>
  </xacro:if>
</robot>
